\contentsline {figure}{\numberline {4.1}{\ignorespaces \xpg@aux {}{english}\ignorespaces Two-hop relay system model: source transmits through two channels with a neural network relay in between.}}{30}{figure.caption.57}%
\contentsline {figure}{\numberline {4.2}{\ignorespaces \xpg@aux {}{english}\ignorespaces Detailed two-hop relay system model with MIMO Hop 2 channel and equalizer. The relay neural network denoises the Hop 1 received signal before retransmission.}}{31}{figure.caption.60}%
\contentsline {figure}{\numberline {4.3}{\ignorespaces \xpg@aux {}{english}\ignorespaces Constellation diagrams. (a) BPSK: 2 real-valued symbols at \(\pm 1\). (b) QPSK: 4 Gray-coded symbols on the unit circle. (c) 16-QAM: 16 Gray-coded symbols on a \(4 \times 4\) rectangular grid with decision boundaries (dotted lines). (d) 16-PSK: 16 Gray-coded symbols uniformly spaced on the unit circle. All constellations are normalised to unit average power.}}{43}{figure.caption.69}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {5.1}{\ignorespaces \xpg@aux {}{english}\ignorespaces E1 --- Consolidated channel model validation: theory vs.\ simulation for AWGN, Rayleigh, and Rician channels (top row) and MIMO equalizer comparison (bottom row). All simulated curves fall within the 95\,\% confidence interval of the theoretical predictions, confirming framework accuracy.}}{49}{figure.caption.76}%
\contentsline {figure}{\numberline {5.2}{\ignorespaces \xpg@aux {}{english}\ignorespaces E2 --- SISO BPSK on AWGN: BER vs.\ SNR for all nine relay strategies with 95\,\% CI. AI relays outperform AF and DF at low SNR (0--4\,dB); classical DF dominates at medium-to-high SNR ($\geq 6$\,dB).}}{50}{figure.caption.77}%
\contentsline {figure}{\numberline {5.3}{\ignorespaces \xpg@aux {}{english}\ignorespaces E3 --- MIMO 2$\times $2 equalizer comparison: single-hop BER with ZF, MMSE, and SIC equalization. MMSE provides $\sim $1--2\,dB gain over ZF; SIC provides an additional $\sim $0.5--1\,dB gain. The equalization hierarchy holds for all relay types.}}{51}{figure.caption.78}%
\contentsline {figure}{\numberline {5.4}{\ignorespaces \xpg@aux {}{english}\ignorespaces E4 --- Normalised 3K-parameter comparison across all channels. At equal parameter budgets, all architectures converge to similar BER, with VAE being the consistent underperformer. The gap between feedforward and sequence models narrows to $\sim $1\,\% BER.}}{52}{figure.caption.79}%
\contentsline {figure}{\numberline {5.5}{\ignorespaces \xpg@aux {}{english}\ignorespaces E5 --- Combined modulation comparison on AWGN: all nine relays across BPSK (solid), QPSK (dashed, overlapping BPSK), and 16-QAM (dotted). The BPSK/QPSK overlap confirms I/Q splitting equivalence. The 16-QAM dotted curves reveal the AI relay BER floor ($\approx $0.18--0.25) that constellation-aware training eliminates.}}{53}{figure.caption.80}%
\contentsline {figure}{\numberline {5.6}{\ignorespaces \xpg@aux {}{english}\ignorespaces E6 --- Top-3 neural relay architectures for 16-QAM in Rayleigh fading. All three best-performing variants use Input LayerNorm (+LN) without CSI injection, confirming that LayerNorm is universally beneficial while CSI injection degrades amplitude-dependent modulations.}}{54}{figure.caption.81}%
\contentsline {figure}{\numberline {5.7}{\ignorespaces \xpg@aux {}{english}\ignorespaces E7 --- 16-QAM BER vs.\ SNR for all relay variants (4-class and 16-class) on AWGN. The 4-class variants (dashed) plateau at BER $\approx 0.008$ while the 16-class variants (solid) continue decreasing, approaching and matching the DF baseline at 20\,dB.}}{55}{figure.caption.82}%
\contentsline {figure}{\numberline {5.8}{\ignorespaces \xpg@aux {}{english}\ignorespaces E8 --- Performance comparison of the E2E autoencoder against the modular relay-based approaches. The E2E system does not achieve lower BER than the two-hop DF relay at any SNR point, demonstrating the superiority of modular design over black-box end-to-end optimisation.}}{56}{figure.caption.83}%
